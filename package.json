{
  "name": "supabase-common-monorepo",
  "private": true,
  "type": "module",
  "license": "MIT",
  "author": "Richard Torcato",
  "packageManager": "pnpm@11.9.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rtorcato/supabase-common.git"
  },
  "scripts": {
    "build": "pnpm --filter \"./packages/*\" build",
    "verify": "pnpm --filter \"./packages/*\" verify",
    "check": "biome check .",
    "check:fix": "biome check --fix .",
    "knip": "knip",
    "test": "pnpm --filter \"./packages/*\" exec vitest run",
    "changeset": "changeset",
    "version": "changeset version",
    "release": "changeset publish",
    "prepare": "husky"
  },
  "devDependencies": {
    "@rtorcato/js-tooling": "latest",
    "@biomejs/biome": "^2.5.1",
    "@changesets/cli": "^2.31.1",
    "@commitlint/cli": "^21.2.1",
    "@commitlint/config-conventional": "^20.0.0",
    "husky": "^9.0.0",
    "knip": "^6.0.0",
    "lint-staged": "^17.0.8",
    "typescript": "^5.6.3"
  },
  "lint-staged": {
    "*.{js,ts,jsx,tsx}": "biome check --fix --no-errors-on-unmatched",
    "*.{json,md,yml,yaml}": "biome format --write --no-errors-on-unmatched"
  },
  "engines": {
    "node": ">=22"
  }
}

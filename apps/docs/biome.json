{
  "$schema": "https://biomejs.dev/schemas/2.5.0/schema.json",
  "root": false,
  "extends": ["@rtorcato/js-tooling/biome"],
  "files": {
    "includes": ["!**/.docusaurus", "!**/build", "!**/node_modules", "!**/docs/api"]
  },
  "overrides": [
    {
      "includes": ["**/src/css/custom.css"],
      "linter": {
        "rules": {
          "complexity": { "noImportantStyles": "off" },
          "style": { "noDescendingSpecificity": "off" }
        }
      }
    }
  ]
}

{
  "extends": "@rtorcato/js-tooling/typescript/base",
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@/*": [
        "./src/*"
      ],
      "~/*": [
        "./src/*"
      ]
    },
    "outDir": "./dist",
    "rootDir": "."
  },
  "include": [
    "src/**/*",
    "tests/**/*",
    "reset.d.ts"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "build"
  ]
}
